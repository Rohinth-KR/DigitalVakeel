# ============================================================
#  Digital-Vakeel — Backend Environment Variables (TEMPLATE)
#  Copy this file to .env and fill in your real values.
#  This file is safe to commit to Git (no real secrets here).
# ============================================================

# ── JWT ──────────────────────────────────────────────────────
# Generate a strong random string for production
JWT_SECRET=your-strong-secret-key-here

# ── Supabase (Database) ───────────────────────────────────────
# Get these from: https://supabase.com → Your Project → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-anon-key-here

# ── Groq (RAG / LLM) ─────────────────────────────────────────
# Get your key from: https://console.groq.com
GROQ_API_KEY=your-groq-api-key-here

# ── Twilio (WhatsApp Notices) ─────────────────────────────────
# Get these from: https://console.twilio.com
TWILIO_SID=your-twilio-account-sid
TWILIO_TOKEN=your-twilio-auth-token
TWILIO_FROM=whatsapp:+14155238886

# ── Resend (Email Notices) ────────────────────────────────────
# Get your key from: https://resend.com/api-keys
RESEND_API_KEY=your-resend-api-key-here
FROM_EMAIL=onboarding@resend.dev
FROM_NAME=Digital-Vakeel Legal

# ── OCR Microservice ──────────────────────────────────────────
# URL where the form-extractor service is running
OCR_SERVICE_URL=http://localhost:8000/extract
